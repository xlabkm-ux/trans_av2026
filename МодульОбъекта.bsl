//--Заполнение таблицы значений вместо регистра vs_ОтложенноеПроведение
//--Частично из обработки ЗаполнитьРегистрAV
//--Возврат "БылаПроводкаAV" - Истина или Ложь и Таблицы с документами

&НаСервере
Функция ПолучениеДанныхНаОтложенноеПроведение(ДатаН, ДатаО) экспорт
		
	УстановитьПривилегированныйРежим(Истина);	
	
	Попытка
		СтруктураРезультата = Новый Структура;
	
	
	//--Запрос вернул
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
	"ВЫБРАТЬ
	|	Хозрасчетный.Регистратор КАК Регистратор,
	|	Хозрасчетный.СчетДт КАК СчетДт,
	|	Хозрасчетный.СчетКт КАК СчетКт,
	|	Хозрасчетный.Период КАК Период
	|ПОМЕСТИТЬ втПроводки
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный КАК Хозрасчетный
	|ГДЕ
	|	Хозрасчетный.СчетДт = &Счет62
	|	И Хозрасчетный.Период >= &ДатаНач
	|	И Хозрасчетный.Период < &ДатаОкон
	|
	|СГРУППИРОВАТЬ ПО
	|	Хозрасчетный.Регистратор,
	|	Хозрасчетный.СчетДт,
	|	Хозрасчетный.СчетКт,
	|	Хозрасчетный.Период
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	Хозрасчетный.Регистратор,
	|	Хозрасчетный.СчетДт,
	|	Хозрасчетный.СчетКт,
	|	Хозрасчетный.Период
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный КАК Хозрасчетный
	|ГДЕ
	|	Хозрасчетный.СчетДт = &Счет76
	|	И Хозрасчетный.Период >= &ДатаНач
	|	И Хозрасчетный.Период < &ДатаОкон
	|
	|СГРУППИРОВАТЬ ПО
	|	Хозрасчетный.Регистратор,
	|	Хозрасчетный.СчетДт,
	|	Хозрасчетный.СчетКт,
	|	Хозрасчетный.Период
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	Хозрасчетный.Регистратор,
	|	Хозрасчетный.СчетДт,
	|	Хозрасчетный.СчетКт,
	|	Хозрасчетный.Период
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный КАК Хозрасчетный
	|ГДЕ
	|	Хозрасчетный.СчетКт = &Счет62
	|	И Хозрасчетный.Период >= &ДатаНач
	|	И Хозрасчетный.Период < &ДатаОкон
	|
	|СГРУППИРОВАТЬ ПО
	|	Хозрасчетный.Регистратор,
	|	Хозрасчетный.СчетДт,
	|	Хозрасчетный.СчетКт,
	|	Хозрасчетный.Период
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	Хозрасчетный.Регистратор,
	|	Хозрасчетный.СчетДт,
	|	Хозрасчетный.СчетКт,
	|	Хозрасчетный.Период
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный КАК Хозрасчетный
	|ГДЕ
	|	Хозрасчетный.СчетКт = &Счет76
	|	И Хозрасчетный.Период >= &ДатаНач
	|	И Хозрасчетный.Период < &ДатаОкон
	|
	|СГРУППИРОВАТЬ ПО
	|	Хозрасчетный.Регистратор,
	|	Хозрасчетный.СчетДт,
	|	Хозрасчетный.СчетКт,
	|	Хозрасчетный.Период
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втПроводки.Регистратор КАК Документ,
	|	втПроводки.Период КАК Период
	|ИЗ
	|	втПроводки КАК втПроводки
	//|ГДЕ
	//|	втПроводки.Регистратор ССЫЛКА Документ.КорректировкаРеализации
	|
	|СГРУППИРОВАТЬ ПО
	|	втПроводки.Регистратор,
	|	втПроводки.Период
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	внут.Регистратор КАК Документ,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА Хозрасчетный.Регистратор ЕСТЬ NULL
	|				ТОГДА ЛОЖЬ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ) КАК ЕстьПроводкаAV
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВсеДанные.Регистратор КАК Регистратор
	|	ИЗ
	|		втПроводки КАК ВсеДанные
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ВсеДанные.Регистратор) КАК внут
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрБухгалтерии.Хозрасчетный КАК Хозрасчетный
	|		ПО (Хозрасчетный.Регистратор = внут.Регистратор)
	|			И (Хозрасчетный.СчетДт = &СчетAV62
	|				ИЛИ Хозрасчетный.СчетДт = &СчетAV76
	|				ИЛИ Хозрасчетный.СчетКт = &СчетAV62
	|				ИЛИ Хозрасчетный.СчетКт = &СчетAV76)
	|
	|СГРУППИРОВАТЬ ПО
	|	внут.Регистратор
	|
	|ИМЕЮЩИЕ
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА Хозрасчетный.Регистратор ЕСТЬ NULL
	|				ТОГДА ЛОЖЬ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ) = ИСТИНА
	|";
					   
		Запрос.УстановитьПараметр("Счет62", ПланыСчетов.Хозрасчетный.РасчетыПоАвансамПолученным);
		Запрос.УстановитьПараметр("Счет76", ПланыСчетов.Хозрасчетный.НДСпоАвансамИПредоплатам);
	
		Запрос.УстановитьПараметр("СчетAV62", ПланыСчетов.Хозрасчетный.НайтиПоКоду("AV.62"));
		Запрос.УстановитьПараметр("СчетAV76", ПланыСчетов.Хозрасчетный.НайтиПоКоду("AV.76"));

		Запрос.УстановитьПараметр("ДатаНач",  ДатаН); 
		Запрос.УстановитьПараметр("ДатаОкон", ДатаО+1); 
	
		ПакетЗапроса = Запрос.ВыполнитьПакет();
	
		УжеВыполненоAV = ПакетЗапроса[2].Выгрузить();
		Если УжеВыполненоAV.Количество() > 0 тогда
			СтруктураРезультата.Вставить("БылаПроводкаAV", Истина);
		Иначе
			СтруктураРезультата.Вставить("БылаПроводкаAV", Ложь);
		КонецЕсли;
	
		ТаблицаЗапроса = ПакетЗапроса[1].Выгрузить();
		//ТаблицаЗапроса = Запрос.Выполнить().Выгрузить();
		СтруктураРезультата.Вставить("ТаблицаЗапроса", ТаблицаЗапроса);
	Исключение
		УстановитьПривилегированныйРежим(Ложь);
		ВызватьИсключение;
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат СтруктураРезультата;
	
КонецФункции

//--Проводки по счетам из обработки
//--Частично из обработки vsОтложенноеПроведение

Процедура ВыполнитьПроводкиПоСчетам(вхДетальныеЗаписи, ПараметрыДлительнойОперации = Неопределено) Экспорт
		
	УстановитьПривилегированныйРежим(Истина);	
	
	Попытка
		//--Общие переменные
		СчетAV62 = ПланыСчетов.Хозрасчетный.НайтиПоКоду("AV.62");
		СчетAV76 = ПланыСчетов.Хозрасчетный.НайтиПоКоду("AV.76");
		
		СоответствиеОтработанных = Новый Соответствие;
		РегистрХозрасчетный = РегистрыБухгалтерии.Хозрасчетный;
		
		Счет1909 = ПланыСчетов.Хозрасчетный.НайтиПоКоду("19.09");
		Счет9101 = ПланыСчетов.Хозрасчетный.НайтиПоКоду("91.01");
		
		Реквизиты62 = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СчетAV62,
		"УчетПоПодразделениям,НалоговыйУчет,Валютный,Количественный");
		Реквизиты76 = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СчетAV76,
		"УчетПоПодразделениям,НалоговыйУчет,Валютный,Количественный");
		//--
		
		ВсегоСтрок = вхДетальныеЗаписи.Количество();
		ШагОбновленияПрогресса = Макс(1000, Цел(ВсегоСтрок / 50)); // не чаще 50 сообщений и не чаще, чем на 1000 строк
		Если ШагОбновленияПрогресса = 0 Тогда
			ШагОбновленияПрогресса = 1;
		КонецЕсли;
		
		Если ПараметрыДлительнойОперации <> Неопределено Тогда
			ДлительныеОперации.СообщитьПрогресс(0, "Запуск обработки документов");
		КонецЕсли;
		
		Если ВсегоСтрок = 0 Тогда
			Если ПараметрыДлительнойОперации <> Неопределено Тогда
				ДлительныеОперации.СообщитьПрогресс(100, "Нет данных для обработки");
			КонецЕсли;
			Возврат;
		КонецЕсли;
		
		ИндексСтроки = 0;
		
		Для Каждого ВыборкаДетальныеЗаписи из вхДетальныеЗаписи Цикл
			
			ИндексСтроки = ИндексСтроки + 1;
		
			НХ  = РегистрХозрасчетный.СоздатьНаборЗаписей();
			Если СоответствиеОтработанных.Получить(ВыборкаДетальныеЗаписи.Документ) = Истина Тогда
				Продолжить;					
			КонецЕсли;
		
			СоответствиеОтработанных.Вставить(ВыборкаДетальныеЗаписи.Документ, Истина);
		
			НХ.Отбор.Регистратор.Установить(ВыборкаДетальныеЗаписи.Документ);
			НХ.Прочитать();
		
		// Удаляем строки AV
		НомераСтрок = Новый СписокЗначений;
		
		Для каждого Запись из НХ Цикл
			Если    Запись.СчетДт = СчетAV62 или Запись.СчетКт = СчетAV62 или 
					Запись.СчетКт = СчетAV76 или Запись.СчетДт = СчетAV76 
					Тогда
				НомераСтрок.Добавить(Запись.НомерСтроки-1);
			КонецЕсли;		
			
		КонецЦикла;
		
		НомераСтрок.СортироватьПоЗначению(НаправлениеСортировки.Убыв);
		Для каждого Ном из НомераСтрок Цикл
			НХ.Удалить(Ном.Значение);
		КонецЦикла;
		
		// Формируем записи AV
			Для каждого ЗаписьНХ из НХ Цикл
			
			// Движение по счету AV.62
			Если ЗаписьНХ.СчетДт = ПланыСчетов.Хозрасчетный.РасчетыПоАвансамПолученным Тогда
				
				ДокументыРасчетовСКонтрагентами = ЗаписьНХ.СубконтоДт.ДокументыРасчетовСКонтрагентами;
				СтавкаНДС = ОпределитьСтавкуНДС(ДокументыРасчетовСКонтрагентами, ЗаписьНХ.Период); 
				
				Движение = НХ.Добавить(); 
				ЗаполнитьЗначенияСвойств(Движение, ЗаписьНХ,,"СчетКт,СубконтоКт,СуммаВРКт,
				|СуммаНУКт,ВалютаКт,КоличествоКт,СуммаПРКт,ВалютнаяСуммаКт,ПодразделениеКт" 
				+ ?(Реквизиты62.УчетПоПодразделениям,"",",ПодразделениеДт")
				+ ?(Реквизиты62.НалоговыйУчет,"",",СуммаНУДт")
				+ ?(Реквизиты62.Валютный,"",",ВалютаДт")
				+ ?(Реквизиты62.Количественный,"",",КоличествоДт")
				);
				Движение.СчетДт = СчетAV62; 
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "Контрагенты", 						ЗаписьНХ.СубконтоДт.Контрагенты);
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "СтавкиНДС", 						СтавкаНДС);
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "ДокументыРасчетовСКонтрагентами", 	ДокументыРасчетовСКонтрагентами);
				
			КонецЕсли;
			
			
			Если ЗаписьНХ.СчетКт = ПланыСчетов.Хозрасчетный.РасчетыПоАвансамПолученным Тогда
				
				ДокументыРасчетовСКонтрагентами = ЗаписьНХ.СубконтоКт.ДокументыРасчетовСКонтрагентами;
				СтавкаНДС = ОпределитьСтавкуНДС(ДокументыРасчетовСКонтрагентами, ЗаписьНХ.Период); 
				
				Движение = НХ.Добавить(); 
				
				ЗаполнитьЗначенияСвойств(Движение, ЗаписьНХ,,"СчетДт,СубконтоДт,СуммаВРДт,
				|СуммаНУДт,ВалютаДт,КоличествоДт,СуммаПРДт,ВалютнаяСуммаДт,ПодразделениеДт" 
				+ ?(Реквизиты62.УчетПоПодразделениям,"",",ПодразделениеКт")
				+ ?(Реквизиты62.НалоговыйУчет,"",",СуммаНУКт")
				+ ?(Реквизиты62.Валютный,"",",ВалютаКт")
				+ ?(Реквизиты62.Количественный,"",",КоличествоКт")
				);
				
				Движение.СчетКт = СчетAV62; 
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Контрагенты", 						ЗаписьНХ.СубконтоКт.Контрагенты);
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "СтавкиНДС", 						СтавкаНДС);
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "ДокументыРасчетовСКонтрагентами", 	ДокументыРасчетовСКонтрагентами);
				
			КонецЕсли;
			
			// Движение по счету AV.76
			Если ЗаписьНХ.СчетДт = ПланыСчетов.Хозрасчетный.НДСпоАвансамИПредоплатам Тогда
				
				СФВыданные = ЗаписьНХ.СубконтоДт.СФВыданные;
				СтавкаНДС = ОпределитьСтавкуНДС(СФВыданные, ЗаписьНХ.Период); 
				
				Движение = НХ.Добавить(); 
				
				ЗаполнитьЗначенияСвойств(Движение, ЗаписьНХ,,"СчетКт,СубконтоКт,СуммаВРКт,
				|СуммаНУКт,ВалютаКт,КоличествоКт,СуммаПРКт,ВалютнаяСуммаКт,ПодразделениеКт" 
				+ ?(Реквизиты76.УчетПоПодразделениям,"",",ПодразделениеДт")
				+ ?(Реквизиты76.НалоговыйУчет,"",",СуммаНУДт")
				+ ?(Реквизиты76.Валютный,"",",ВалютаДт")
				+ ?(Реквизиты76.Количественный,"",",КоличествоДт")
				);
				
				Движение.СчетДт = СчетAV76; 
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "Контрагенты", 						ЗаписьНХ.СубконтоДт.Контрагенты);
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "СтавкиНДС", 						СтавкаНДС);
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "СФВыданные", 						СФВыданные);
				
			КонецЕсли;

			Если ЗаписьНХ.СчетКт = ПланыСчетов.Хозрасчетный.НДСпоАвансамИПредоплатам Тогда
				
				СФВыданные = ЗаписьНХ.СубконтоКт.СФВыданные;
				СтавкаНДС = ОпределитьСтавкуНДС(СФВыданные, ЗаписьНХ.Период); 
				
				Движение = НХ.Добавить(); 
				
				ЗаполнитьЗначенияСвойств(Движение, ЗаписьНХ,,"СчетДт,СубконтоДт,СуммаВРДт,
				|СуммаНУДт,ВалютаДт,КоличествоДт,СуммаПРДт,ВалютнаяСуммаДт,ПодразделениеДт" 
				+ ?(Реквизиты76.УчетПоПодразделениям,"",",ПодразделениеКт")
				+ ?(Реквизиты76.НалоговыйУчет,"",",СуммаНУКт")
				+ ?(Реквизиты76.Валютный,"",",ВалютаКт")
				+ ?(Реквизиты76.Количественный,"",",КоличествоКт")
				);
				
				
				Движение.СчетКт = СчетAV76; 
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Контрагенты", 						ЗаписьНХ.СубконтоКт.Контрагенты);
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "СтавкиНДС", 						СтавкаНДС);
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "СФВыданные", 	                    СФВыданные);
				
			КонецЕсли;
			
			// Особый случай очистки СуммаНУКт
			Если (ЗаписьНХ.СчетДт = Счет1909) И (ЗаписьНХ.СчетКт = Счет9101) Тогда
				ЗаписьНХ.СуммаНУКт = 0;
			КонецЕсли;
			
			КонецЦикла;
		
			Если НХ.Количество()>0 Тогда
				НХ.ДополнительныеСвойства.Вставить("ДобавитьПроводки", Истина);
				НХ.ДополнительныеСвойства.Вставить("СуммыНалоговогоУчетаЗаполнены", Истина);
				НХ.Записать();
			КонецЕсли;
			
			Если ПараметрыДлительнойОперации <> Неопределено Тогда
				Если (ИндексСтроки = 1) 
					ИЛИ (ИндексСтроки = ВсегоСтрок) 
					ИЛИ (ИндексСтроки % ШагОбновленияПрогресса = 0) Тогда
					
					Процент = Цел(ИндексСтроки * 100 / ВсегоСтрок);
					ДлительныеОперации.СообщитьПрогресс(
						Процент,
						"Обработано " + Формат(ИндексСтроки, "ЧГ=0") + " из " + Формат(ВсегоСтрок, "ЧГ=0"));
				КонецЕсли;
			КонецЕсли;
				
		КонецЦикла;
		
		Если ПараметрыДлительнойОперации <> Неопределено Тогда
			ДлительныеОперации.СообщитьПрогресс(100, "Обработка документов завершена");
		КонецЕсли;
	Исключение
		УстановитьПривилегированныйРежим(Ложь);
		ВызватьИсключение;
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

Функция ОпределитьСтавкуНДС(ИсточникДаты, ДатаПоУмолчанию = Неопределено)
	
	ДатаДокумента = Неопределено;
	
	Если ТипЗнч(ИсточникДаты) = Тип("Дата") Тогда
		ДатаДокумента = ИсточникДаты;
	ИначеЕсли ЗначениеЗаполнено(ИсточникДаты) Тогда
		Попытка
			ДатаДокумента = ИсточникДаты.Дата;
		Исключение
			ДатаДокумента = Неопределено;
		КонецПопытки;
	КонецЕсли;
	
	Если (ДатаДокумента = Неопределено) И (ТипЗнч(ДатаПоУмолчанию) = Тип("Дата")) Тогда
		ДатаДокумента = ДатаПоУмолчанию;
	КонецЕсли;
	
	Если ДатаДокумента = Неопределено Тогда
		ВызватьИсключение "Не удалось определить дату для расчета ставки НДС.";
	КонецЕсли;
	
	Если ДатаДокумента >= Дата("20260101") Тогда
		Возврат Перечисления.СтавкиНДС.НДС22;
	ИначеЕсли ДатаДокумента >= Дата("20190101") Тогда
		Возврат Перечисления.СтавкиНДС.НДС20;
	Иначе
		Возврат Перечисления.СтавкиНДС.НДС18;
	КонецЕсли;
	
КонецФункции	
