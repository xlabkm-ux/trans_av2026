//--Запуск длительного проведения через БСП

&НаСервере
Функция ЗапуститьПроведениеБСП(АдресТаблицыДокументов) Экспорт
	
	Параметры = ДлительныеОперации.ПараметрыВыполненияПроцедуры();
	Параметры.Наименование = "Создание AV проводок";
	
	Возврат ДлительныеОперации.ВыполнитьПроцедуру(
		Параметры,
		"ВнешняяОбработка.СозданиеAVПроводок.МодульОбъекта.ВыполнитьПроведениеБСПФон",
		АдресТаблицыДокументов);
	
КонецФункции

&НаСервереБезКонтекста
Процедура ВыполнитьПроведениеБСПФон(АдресТаблицыДокументов, ПараметрыВыполнения) Экспорт
	
	ТаблицаДокументов = ПолучитьИзВременногоХранилища(АдресТаблицыДокументов);
	Если ТипЗнч(ТаблицаДокументов) <> Тип("ТаблицаЗначений") Тогда
		Возврат;
	КонецЕсли;
	
	ВыполнитьПроводкиПоСчетам(ТаблицаДокументов, ПараметрыВыполнения);
	
КонецПроцедуры

