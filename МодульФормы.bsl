
&НаСервере
Процедура ВыполнитьЗапросНаСервере()
	
	БылоПроведениеAV = Ложь;
	
	ЭтаОбработка = РеквизитФормыВЗначение("Объект");
	лкВыбранныйКвартал = КварталВПериод(ВыбранныйКвартал);
	Если лкВыбранныйКвартал = Неопределено тогда
		Сообщить("Не выбран квартал");
		Возврат;
	КонецЕсли;
	лкСтруктураРезультата = ЭтаОбработка.ПолучениеДанныхНаОтложенноеПроведение(лкВыбранныйКвартал.ДатаНачала, лкВыбранныйКвартал.ДатаОкончания);
	
	Если лкСтруктураРезультата.Свойство("ТаблицаЗапроса") тогда
		ЗначениеВРеквизитФормы(лкСтруктураРезультата["ТаблицаЗапроса"], "РезультатЗапроса");
	КонецЕсли;
	
	Если лкСтруктураРезультата.Свойство("БылаПроводкаAV") тогда
		БылоПроведениеAV = лкСтруктураРезультата["БылаПроводкаAV"];
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьЗапрос(Команда)
	ВыполнитьЗапросНаСервере();
	Если БылоПроведениеAV Тогда
		ЭтаФорма.Элементы.БылоПроведениеAV.ЦветТекстаЗаголовка = Новый Цвет(255, 0, 0);
	Иначе
		ЭтаФорма.Элементы.БылоПроведениеAV.ЦветТекстаЗаголовка = Новый Цвет(0, 0, 0);
	КонецЕсли;
КонецПроцедуры

//--Работа с проведением

&НаКлиенте
Процедура СоздатьПроведения(Команда)
	
	ВыполнитьЗапросНаСервере();
	Если БылоПроведениеAV тогда
		//Оповещение = Новый ОписаниеОповещения("РеакцияНаВопрос", ЭтотОбъект, Параметры);
		//ПоказатьВопрос(Оповещение, "За данный квартал уже были AV проводки. Все равно выполнить проведение?", РежимДиалогаВопрос.ДаНет,,,"ВНИМАНИЕ!!!");
		Оповещение = Новый ОписаниеОповещения("РеакцияНаВопрос", ЭтотОбъект);
		ОткрытьФорму("ВнешняяОбработка.СозданиеAVПроводок.Форма.ФормаВопроса", , , , , , Оповещение);
	Иначе
		ЗапуститьСозданиеПроведенийДлительно();	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РеакцияНаВопрос(Результат, Параметры) экспорт
	
	Если Результат = Истина тогда
		ЗапуститьСозданиеПроведенийДлительно();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьСозданиеПроведенийДлительно()
	
	ДлительнаяОперация = СоздатьПроведенияНаСервереДлительно();
	ПоследнийПроцентПроведения = -1;
	
	Если ДлительнаяОперация = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ДлительнаяОперация.Свойство("ИдентификаторЗадания") Тогда
		ИдентификаторЗаданияПроведения = ДлительнаяОперация.ИдентификаторЗадания;
	Иначе
		ИдентификаторЗаданияПроведения = Неопределено;
	КонецЕсли;
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ПослеЗавершенияПроведения", ЭтотОбъект);
	ОповещениеОПрогрессе = Новый ОписаниеОповещения("ОбновитьПрогрессПроведения", ЭтотОбъект);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтаФорма);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	ПараметрыОжидания.ОповещениеОПрогрессеВыполнения = ОповещениеОПрогрессе;
	ПараметрыОжидания.Интервал = 1;
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПрогрессПроведения(Состояние, ДополнительныеПараметры) Экспорт
	
	Если Состояние = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущийПроцент = 0;
	ТекстСостояния = "";
	СтатусСостояния = "";
	
	Если Состояние.Свойство("Прогресс") Тогда
		ТекущийПроцент = Состояние.Прогресс;
	КонецЕсли;
	Если Состояние.Свойство("СообщениеПользователю") Тогда
		ТекстСостояния = Состояние.СообщениеПользователю;
	КонецЕсли;
	Если Состояние.Свойство("Статус") Тогда
		СтатусСостояния = Строка(Состояние.Статус);
	КонецЕсли;
	
	// Для тестирования: не чаще, чем при смене процента.
	Если ТекущийПроцент <> ПоследнийПроцентПроведения Тогда
		ПоследнийПроцентПроведения = ТекущийПроцент;
		
		ЭлементПрогресса = Элементы.Найти("Прогресс");
		Если ЭлементПрогресса <> Неопределено Тогда
			ЭлементПрогресса.Значение = ТекущийПроцент;
		КонецЕсли;
		
		ЭлементСтатуса = Элементы.Найти("Статус");
		Если ЭлементСтатуса <> Неопределено Тогда
			ЭлементСтатуса.Заголовок = ТекстСостояния;
		КонецЕсли;
	КонецЕсли;
	
	// Завершение операции отслеживается в ПослеЗавершенияПроведения.
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗавершенияПроведения(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Сообщить("Создание AV проводок отменено.");
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		СтандартныеПодсистемыКлиент.ВывестиИнформациюОбОшибке(Результат.ИнформацияОбОшибке);
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		Сообщить("Создание AV проводок завершено.");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СоздатьПроведенияНаСервереДлительно()
	
	ЭтаОбработка = РеквизитФормыВЗначение("Объект");
	ТаблицаДокументов = РеквизитФормыВЗначение("РезультатЗапроса");
	АдресТаблицыДокументов = ПоместитьВоВременноеХранилище(ТаблицаДокументов);
	
	Возврат ЭтаОбработка.ЗапуститьПроведениеБСП(АдресТаблицыДокументов);
	
КонецФункции

&НаСервере
Процедура СоздатьПроведенияНаСервере()
	
	ЭтаОбработка = РеквизитФормыВЗначение("Объект");
	ЭтаОбработка.ВыполнитьПроводкиПоСчетам(РеквизитФормыВЗначение("РезультатЗапроса"));
	
КонецПроцедуры

//--Работа с кварталами.----------------------------- 

&НаКлиенте
Функция СформироватьСписокКварталов()
	
	//лкМассивДат = Новый Массив;
	
	лкСписокЗначений = Новый СписокЗначений;
	
	лкТекущаяДата = ТекущаяДата();
	//---Возьмем -1 и +1 лет.
	Для лкСчетчикГод = -1 по 1 цикл
		лкГод = ДобавитьМесяц(лкТекущаяДата, 12 * лкСчетчикГод);
		лкТекстГод = Формат(лкГод, "ДФ=гггг");
		Для лкСчетчникКварталов = 1 по 4 цикл
			лкЗначение = "" + лкСчетчникКварталов + "_" + лкТекстГод;
			лкПредставление = "" + лкСчетчникКварталов + " квартал " + лкТекстГод + " г.";
			
			//лкМассивДат.Добавить(лкЗначение);
			
			лкСписокЗначений.Добавить(лкЗначение, лкПредставление);
		КонецЦикла;		
	КонецЦикла;
	
	Возврат  лкСписокЗначений;
	
КонецФункции

&НаКлиенте
Функция ПолучитьТекущийКвартал()
	
	лкТекущаяДата = ТекущаяДата();
	
	лкТекущийКвартал = Цел((Месяц(лкТекущаяДата)+2)/3);
	лкТекущийГод = Формат(лкТекущаяДата, "ДФ=гггг");
	
	Возврат "" + лкТекущийКвартал + "_" + лкТекущийГод;
	
КонецФункции

&НаСервереБезКонтекста
Функция КварталВПериод(вхКварталГод)
	
	Если Не ЗначениеЗаполнено(вхКварталГод) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	СоставПериода = СтрРазделить(вхКварталГод, "_", ложь);
	Если СоставПериода.Количество() <> 2 тогда
		Возврат Неопределено;	
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СоставПериода[0]) ИЛИ Не ЗначениеЗаполнено(СоставПериода[1]) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		лкКвартал = Число(СоставПериода[0]);
		лкГод = Число(СоставПериода[1]);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Если (лкКвартал < 1) ИЛИ (лкКвартал > 4) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если лкГод < 1900 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	лкНачДата = Дата(лкГод, (лкКвартал-1) * 3 + 1, 1);
	
	лкПериод = новый СтандартныйПериод;
	лкПериод.ДатаНачала = лкНачДата;
	лкПериод.ДатаОкончания = КонецКвартала(лкНачДата);
	
	Возврат лкПериод;

КонецФункции

//--Блок формы

&НаКлиенте
Процедура РезультатЗапросыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ТекДан = Элементы.РезультатЗапроса.ТекущиеДанные;
	Если ТекДан = Неопределено тогда
		Возврат;
	КонецЕсли;
	ОткрытьЗначениеАсинх(ТекДан.Документ);
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	лкСписокКварталов = СформироватьСписокКварталов();
	Для Каждого лкЭлементСписка из лкСписокКварталов цикл
		Элементы.ВыбранныйКвартал.СписокВыбора.Добавить(лкЭлементСписка.Значение, лкЭлементСписка.Представление);
	КонецЦикла;
	ВыбранныйКвартал = ПолучитьТекущийКвартал();
КонецПроцедуры





